rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.firstName is string && data.firstName.size() <= 50 &&
             data.lastName is string && data.lastName.size() <= 50 &&
             data.email is string && data.email.size() <= 100 &&
             data.walletBalance is number;
    }

    function isValidGroup(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.amount is number && data.amount > 0 &&
             data.adminId == request.auth.uid &&
             data.status in ['active', 'completed'];
    }

    function isValidMember(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.position is number &&
             data.status is string;
    }

    function isValidContribution(data) {
      return data.userId is string && 
             data.amount is number && 
             data.week is number && 
             data.status == 'paid';
    }

    // --- Collections ---

    function isValidMembership(data) {
      return data.groupId is string && 
             data.name is string && 
             data.amount is number && 
             data.cycle is string && 
             data.maxMembers is number;
    }

    function isValidNotification(data) {
      return data.userId is string && 
             data.title is string && 
             (data.message is string || data.desc is string) &&
             data.category is string && 
             data.type is string &&
             data.read == false;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; 
      allow create: if isSignedIn();
      allow update: if isOwner(userId);

      match /memberships/{groupId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }

    match /groups/{groupId} {
      allow read, write: if isSignedIn();

      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }

      match /contributions/{contribId} {
        allow read, write: if isSignedIn();
      }
    }

    match /transactions/{txId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    match /notifications/{notifId} {
      allow read, write: if isSignedIn();
    }

    // --- Relational Helpers ---
    function isGroupAdmin(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data.adminId == request.auth.uid;
    }
    
    function isGroupMember(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }
  }
}
